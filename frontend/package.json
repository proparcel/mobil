{
  "name": "frontend",
  "main": "index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "set NODE_ENV=development&& react-native start",
    "start:tunnel": "npx expo start --tunnel --clear --scheme proparcel",
    "start:dev": "set NODE_ENV=development&& react-native start --reset-cache",
    "stop:metro": "powershell -NoProfile -Command \"$p=(Get-NetTCPConnection -LocalPort 8081 -EA SilentlyContinue|Select -First 1).OwningProcess;if($p){Stop-Process -Id $p -Force;Write-Host ('Metro durduruldu PID '+$p)}else{Write-Host '8081 bos'}\"",
    "reset-project": "node ./scripts/reset-project.js",
    "gen:model-packs-manifest": "node ./scripts/generate-models-pack-manifest.js",
    "gen:android-asset-packs": "node ./scripts/generate-android-asset-packs.js",
    "gen:debug-assets-models": "node ./scripts/copy-models-to-debug-assets.js",
    "compress-glb": "node ./scripts/compress-glb-for-mobile.js",
    "inspect-glb": "node ./scripts/inspect-glb.js",
    "glb-to-minimal-pbr": "node ./scripts/glb-to-minimal-pbr.js",
    "optimize-glb": "node ./scripts/optimize_glb.js",
    "debug:handlers": "tsx scripts/dump-and-parse-handlers.ts",
    "android": "react-native run-android",
    "android:local": "react-native run-android",
    "android:embed-models": "npm run gen:model-packs-manifest && npm run gen:android-asset-packs && npm run gen:debug-assets-models",
    "android:run-only": "react-native run-android",
    "android:release": "react-native run-android --variant=release",
    "build:apk": "cd android && gradlew.bat assembleRelease",
    "build:apk:with-models": "npm run android:embed-models && cd android && gradlew.bat assembleRelease",
    "ios": "react-native run-ios",
    "eas:ios": "eas build --platform ios --profile preview",
    "eas:dev": "set EAS_NO_VCS=1 && eas build --platform ios --profile development",
    "eas:inspect": "eas build:inspect --platform ios --profile development --stage archive",
    "lint": "eslint .",
    "copy:icon-fonts": "node ./scripts/copy-icon-fonts-to-android.js",
    "postinstall": "patch-package && npm run copy:icon-fonts",
    "preandroid": "npm run copy:icon-fonts",
    "preandroid:local": "npm run copy:icon-fonts",
    "preandroid:run-only": "npm run copy:icon-fonts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/blur": "^4.3.2",
    "@react-native-community/geolocation": "^3.2.1",
    "@react-native-community/slider": "^5.1.2",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.1.6",
    "@rnmapbox/maps": "^10.2.10",
    "@turf/area": "^7.3.5",
    "@turf/buffer": "^7.3.5",
    "@turf/helpers": "^7.3.0",
    "@turf/meta": "^7.3.0",
    "@turf/polygon-to-line": "^7.3.5",
    "@turf/rewind": "^7.3.5",
    "expo-dev-client": "~6.0.20",
    "expo-media-library": "~18.2.1",
    "polygon-clipping": "^0.15.7",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-contacts": "^8.0.4",
    "react-native-dotenv": "^3.4.11",
    "react-native-fs": "^2.20.0",
    "react-native-geolocation-service": "^5.3.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-html-to-pdf": "^0.12.0",
    "react-native-image-picker": "^7.1.2",
    "react-native-inappbrowser-reborn": "^3.6.0",
    "react-native-keep-awake": "^4.0.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-share": "^10.0.2",
    "react-native-splash-screen": "^3.3.0",
    "react-native-static-server": "^0.5.0",
    "react-native-svg": "15.12.1",
    "react-native-vector-icons": "^10.2.0",
    "react-native-video": "^6.19.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/config-plugins": "^10.0.0",
    "@react-native-community/cli": "^14.0.1",
    "@react-native/metro-config": "^0.81.5",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "acorn": "^8.15.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "draco3dgltf": "^1.5.7",
    "eslint": "^9.25.0",
    "expo": "^54.0.0",
    "expo-build-properties": "~1.0.10",
    "meshoptimizer": "^0.18.1",
    "patch-package": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "resolutions": {
    "@turf/helpers": "^7.3.0",
    "@turf/meta": "^7.3.0",
    "@turf/bbox": "^7.3.0",
    "fast-xml-parser": "5.3.5"
  },
  "overrides": {
    "@turf/helpers": "^7.3.0",
    "@turf/meta": "^7.3.0",
    "@turf/bbox": "^7.3.0",
    "fast-xml-parser": "5.3.5"
  },
  "private": true,
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
