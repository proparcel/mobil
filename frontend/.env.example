# ProParcel mobile env
#
# Kalici tek kaynak (onerilen):
#   %USERPROFILE%\.proparcel\mobile.env
#
# Repo icindeki .env sadece override icindir. Build scriptleri ikisini de okur.
# Mimari not: doc/MAPBOX_TOKEN_ARCHITECTURE.md
#
# Mobil → Django API (MongoDB sunucuda, mobilde degil):
#   Production: https://www.proparcel.com
#   Sunucu IP:  http://178.210.168.33:8000
#   33789 = SQL Server portu (mobil API / Metro degil)
#
# Android USB debug (Expo menusu degil, dogrudan ProParcel):
#   Terminal 1: npm run start:dev
#   Terminal 2: npm run android   (veya ilk kurulum: npm run android:reinstall)
# Metro: localhost:8081 (adb reverse). WiFi Metro: gelistirici menusu > Debug server host > PC_IP:8081

EXPO_PUBLIC_API_URL=https://www.proparcel.com
EXPO_PUBLIC_AUTH_API_URL=https://www.proparcel.com
EXPO_PUBLIC_MODELS_URL=https://www.proparcel.com
# EXPO_PUBLIC_DJANGO_API_URL=https://www.proparcel.com

# Mapbox public (harita runtime — pk.*)
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here

# Mapbox SDK indirme (Android/AAB native build — sk.*)
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.your_downloads_token_here

# Google Street View
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Yerel Django (adb reverse tcp:8000 tcp:8000):
# EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
# EXPO_PUBLIC_AUTH_API_URL=http://127.0.0.1:8000
# EXPO_PUBLIC_MODELS_URL=http://127.0.0.1:8000

# Eski isimler (geriye uyumluluk — tercih EXPO_PUBLIC_*):
# API_URL=https://www.proparcel.com
# MODELS_URL=https://www.proparcel.com
